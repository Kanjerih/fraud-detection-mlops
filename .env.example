# Copy to .env and adjust as needed. All values here override the
# defaults in src/config.py (pydantic-settings reads this file automatically).

MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=credit-card-fraud-detection
REGISTERED_MODEL_NAME=fraud-detection-rf

CLASSIFICATION_THRESHOLD=0.3
FALSE_POSITIVE_COST=10.0

MIN_RECALL=0.70
MIN_PRECISION=0.85
MIN_MCC=0.75
